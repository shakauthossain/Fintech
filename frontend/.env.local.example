# ---- Local dev (npm run dev, backend on :8001) ----
NEXT_PUBLIC_API_BASE=http://localhost:8001

# ---- Docker Compose ----
# Leave NEXT_PUBLIC_API_BASE empty so the browser uses same-origin /api/* (proxied).
# INTERNAL_API_URL is set in docker-compose.yml for server-side calls.
# NEXT_PUBLIC_API_BASE=
# INTERNAL_API_URL=http://backend:8001
