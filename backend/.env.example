# ---- Runtime ----
PORT=8001
# poll = local fallback (no public URL needed) | push = Drive watch channel (needs public HTTPS)
DETECTION_MODE=poll
POLL_INTERVAL_MS=5000
MAX_CONCURRENT_FILES=2

# When true (or when Google/OpenRouter creds are missing) the backend runs with
# mocked Drive/LLM/Sheets so the full stack is runnable without external accounts.
MOCK_MODE=true

# ---- Google (Drive + Sheets) ----
GOOGLE_APPLICATION_CREDENTIALS=./secrets/service-account.json
DRIVE_WATCH_FOLDER_ID=
DRIVE_PROCESSED_FOLDER_ID=
SHEETS_SPREADSHEET_ID=

# ---- Push mode only ----
PUBLIC_WEBHOOK_URL=https://your-host/webhooks/drive

# ---- OpenRouter (LLM gateway, OpenAI-compatible) ----
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Stage 1 — OCR vision model (images/scanned PDFs). Digital PDFs skip this step.
OPENROUTER_OCR_MODEL=google/gemma-4-26b-a4b-it:free
# Stage 2 — text model that rearranges OCR output into JSON
# Paid: anthropic/claude-3.5-sonnet  |  Free: openrouter/free
OPENROUTER_MODEL=openrouter/free
OPENROUTER_SITE_URL=https://your-company.example
OPENROUTER_APP_NAME=invoice-pipeline

# ---- Frontend ----
# Browser origin only. In Docker the backend is not exposed; Next.js proxies /api/*.
# Production:
CORS_ORIGINS=https://fintech.riseo.online
# Local dev:
# CORS_ORIGINS=http://localhost:3001

# ---- Auth ----
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
# Set true when served over HTTPS
AUTH_COOKIE_SECURE=true

# ---- Google OAuth (for Settings → Connect Google Drive) ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Production (callback via frontend/nginx proxy):
GOOGLE_OAUTH_REDIRECT_URI=https://fintech.riseo.online/api/setup/google/callback
FRONTEND_URL=https://fintech.riseo.online
# Local dev:
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3001/api/setup/google/callback
# FRONTEND_URL=http://localhost:3001

# ---- Database (Neon PostgreSQL) ----
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require
